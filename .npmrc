# NPM configuration for singravault
# Note: @singra/premium requires NPM_TOKEN for installation from GitHub Packages
# In v0/dev environments without the token, the premiumStub.ts fallback is used

# Only enable GitHub Packages registry when NPM_TOKEN is available
# //npm.pkg.github.com/:_authToken=${NPM_TOKEN}
# @singra:registry=https://npm.pkg.github.com
