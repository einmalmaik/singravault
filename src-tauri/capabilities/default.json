{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the main Singra Vault desktop window.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "deep-link:default",
    "dialog:allow-save",
    "fs:create-app-specific-dirs",
    "fs:allow-applog-read",
    "fs:allow-applog-write",
    "fs:allow-write-file",
    "opener:default",
    "process:allow-restart",
    "updater:default",
    "window-state:default"
  ]
}
